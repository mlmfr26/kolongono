# ─── Base de données ──────────────────────────────────────────────────────────
# Serveur partagé CX23 : PostgreSQL déjà en cours pour Longonia et LX
# Créer uniquement la base santesd + l'utilisateur kolongono_sd
DB_HOST=localhost
DB_PORT=5432
DB_NAME=santesd
DB_USER=kolongono_sd
DB_PASSWORD=changeme

# ─── Sécurité ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_32_chars_min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── IA (pré-diagnostic) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Jitsi Meet (auto-hébergé) ────────────────────────────────────────────────
# Domaine public Jitsi self-hosted (ex: jitsi.santedirect-kolongono.cd)
# Laisser meet.jit.si pour les tests locaux avant déploiement serveur
JITSI_DOMAIN=meet.jit.si
# IP publique du serveur de production (pour JVB NAT traversal)
JITSI_SERVER_IP=YOUR_SERVER_IP
# Mots de passe internes Jitsi — générer avec: openssl rand -hex 16
JICOFO_AUTH_PASSWORD=jicofo_CHANGE_ME_kolongono
JVB_AUTH_PASSWORD=jvb_CHANGE_ME_kolongono

# ─── Longonia bridge ──────────────────────────────────────────────────────────
# En développement local : http://localhost:8000
# Sur le serveur CX23 partagé : http://127.0.0.1:PORT_LONGONIA (même machine)
# Vérifier le port avec : sudo ss -tlnp | grep -E "8000|8001"
LONGONIA_API_URL=http://localhost:8000
LONGONIA_API_KEY=
LONGONIA_SANTE_URL=http://localhost:8001

# ─── Mobile Money ─────────────────────────────────────────────────────────────
MPESA_API_KEY=
MPESA_SHORTCODE=
ORANGE_MONEY_API_KEY=
AIRTEL_MONEY_API_KEY=

# ─── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── SMS ──────────────────────────────────────────────────────────────────────
SMS_API_KEY=
SMS_SENDER_ID=KOLONGONO

# ─── Application ──────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8002
ENVIRONMENT=development
